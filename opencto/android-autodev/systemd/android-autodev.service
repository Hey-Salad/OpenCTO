[Unit]
Description=Android Autodev task runner
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/hs-chilu/heysalad-ai-projects/mobile-apps/android-autodev
ExecStart=/home/hs-chilu/heysalad-ai-projects/mobile-apps/android-autodev/scripts/run.sh
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=default.target
