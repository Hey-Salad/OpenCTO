{
  "expo": {
    "name": "OpenCTO",
    "slug": "opencto-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "opencto",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "works.opencto.mobile",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "OpenCTO uses your microphone for realtime voice conversations."
      }
    },
    "android": {
      "package": "works.opencto.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
