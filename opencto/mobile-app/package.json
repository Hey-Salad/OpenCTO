{
  "name": "opencto-mobile-app",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "build": "expo export --platform ios --output-dir dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@react-navigation/native": "^7.1.28",
    "expo": "~54.0.0",
    "expo-av": "^16.0.8",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.7",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "~19.1.10",
    "eslint": "^9.39.0",
    "eslint-config-expo": "^10.0.0",
    "typescript": "~5.9.2",
    "vitest": "^2.1.9"
  }
}
